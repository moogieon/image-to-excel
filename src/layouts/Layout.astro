---
import '../styles/global.css';
import { languages, t, type Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description = '', lang = 'en' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Ambient color blobs — visible through liquid glass -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-15%] left-[-8%] w-[550px] h-[550px] rounded-full bg-emerald-300/25 blur-[100px] animate-float"></div>
      <div class="absolute top-[40%] right-[-12%] w-[450px] h-[450px] rounded-full bg-teal-200/20 blur-[100px] animate-float-delayed"></div>
      <div class="absolute bottom-[-10%] left-[25%] w-[500px] h-[500px] rounded-full bg-green-200/15 blur-[100px] animate-float"></div>
      <div class="absolute top-[10%] right-[20%] w-[300px] h-[300px] rounded-full bg-lime-200/10 blur-[80px] animate-float-delayed"></div>
    </div>

    <!-- Nav -->
    <header class="liquid-glass-strong sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
        <a href={`/${lang}`} class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 rounded-[10px] bg-gradient-to-br from-[#28A06A] to-[#217346] flex items-center justify-center shadow-sm shadow-primary/20 group-hover:shadow-md group-hover:shadow-primary/30 transition-all duration-300">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
              <polyline points="14 2 14 8 20 8" />
            </svg>
          </div>
          <span class="text-[17px] font-semibold tracking-tight text-secondary">
            Image<span class="text-primary">2</span>Excel
          </span>
        </a>

        <div class="flex items-center gap-2">
          <div class="relative group">
            <button class="btn-glass px-3 py-1.5 rounded-full text-[13px] font-medium text-text-secondary flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-50">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              {languages[lang]}
            </button>
            <div class="absolute right-0 top-full mt-2 liquid-glass-strong rounded-2xl py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 min-w-[140px] translate-y-2 group-hover:translate-y-0">
              {Object.entries(languages).map(([code, name]) => (
                <a
                  href={currentPath.replace(`/${lang}`, `/${code}`)}
                  class:list={[
                    'block px-4 py-2 text-[13px] hover:bg-white/10 transition-colors duration-200 first:rounded-t-xl last:rounded-b-xl',
                    code === lang ? 'text-primary font-semibold' : 'text-text-secondary',
                  ]}
                >
                  {name}
                </a>
              ))}
            </div>
          </div>

          <a
            href={`/${lang}/login`}
            class="btn-glass px-4 py-1.5 rounded-full text-[13px] font-medium text-text-secondary hover:text-text transition-colors duration-200"
          >
            {t(lang, 'nav.login')}
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-auto py-8 text-center">
      <div class="max-w-6xl mx-auto px-5">
        <div class="flex items-center justify-center gap-4 text-[13px] text-text-muted">
          <span>&copy; {new Date().getFullYear()} Image2Excel</span>
          <span class="w-px h-3 bg-border-strong"></span>
          <a href="#" class="hover:text-text transition-colors duration-200">{t(lang, 'footer.privacy')}</a>
          <span class="w-px h-3 bg-border-strong"></span>
          <a href="#" class="hover:text-text transition-colors duration-200">{t(lang, 'footer.terms')}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
