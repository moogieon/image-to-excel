---
import '../styles/global.css';
import { languages, t, type Lang } from '../i18n/translations';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const { title, description = '', lang = 'en' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Ambient blobs — neutral/cool tones for glass bleed-through -->
    <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-10%] left-[5%] w-[600px] h-[600px] rounded-full bg-slate-300/20 blur-[100px] animate-float"></div>
      <div class="absolute top-[35%] right-[0%] w-[500px] h-[500px] rounded-full bg-sky-200/15 blur-[100px] animate-float-delayed"></div>
      <div class="absolute bottom-[0%] left-[20%] w-[550px] h-[550px] rounded-full bg-indigo-200/12 blur-[100px] animate-float"></div>
      <div class="absolute top-[10%] right-[20%] w-[350px] h-[350px] rounded-full bg-gray-300/15 blur-[80px] animate-float-delayed"></div>
    </div>

    <!-- Nav — glass -->
    <header class="liquid-glass-strong sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
        <a href={`/${lang}`} class="flex items-center gap-2.5 group">
          <div class="w-8 h-8 rounded-[10px] overflow-hidden group-hover:opacity-80 transition-opacity duration-300">
            <img src="/images/logo-main.jpg" alt="Image2Excel" width="32" height="32" class="w-full h-full object-cover" />
          </div>
          <span class="text-[17px] font-semibold tracking-tight text-text">
            Image<span class="text-primary-light">2</span>Excel
          </span>
        </a>

        <div class="flex items-center gap-2">
          <div class="relative group">
            <button class="relative z-10 px-3 py-1.5 rounded-full text-[13px] font-medium flex items-center gap-1.5 text-text-secondary hover:text-text transition-colors duration-200">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" />
                <line x1="2" y1="12" x2="22" y2="12" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              {languages[lang]}
            </button>
            <div class="absolute right-0 top-full mt-2 liquid-glass rounded-2xl py-1.5 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 min-w-[140px] translate-y-2 group-hover:translate-y-0 z-50">
              {Object.entries(languages).map(([code, name]) => (
                <a
                  href={currentPath.replace(`/${lang}`, `/${code}`)}
                  class:list={[
                    'relative z-10 block px-4 py-2 text-[13px] hover:bg-black/5 transition-colors duration-200 first:rounded-t-xl last:rounded-b-xl',
                    code === lang ? 'text-primary-light font-semibold' : 'text-text-secondary',
                  ]}
                >
                  {name}
                </a>
              ))}
            </div>
          </div>

          <a
            href={`/${lang}/login`}
            class="relative z-10 px-4 py-1.5 rounded-full text-[13px] font-medium text-text-secondary hover:text-text transition-colors duration-200"
          >
            {t(lang, 'nav.login')}
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-auto py-8 text-center">
      <div class="max-w-6xl mx-auto px-5">
        <div class="flex items-center justify-center gap-4 text-[13px] text-text-muted">
          <span>&copy; {new Date().getFullYear()} Image2Excel</span>
          <span class="w-px h-3 bg-border-strong"></span>
          <a href="#" class="hover:text-text transition-colors duration-200">{t(lang, 'footer.privacy')}</a>
          <span class="w-px h-3 bg-border-strong"></span>
          <a href="#" class="hover:text-text transition-colors duration-200">{t(lang, 'footer.terms')}</a>
        </div>
      </div>
    </footer>
  </body>
</html>
