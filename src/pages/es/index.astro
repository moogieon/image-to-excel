---
import Layout from '../../layouts/Layout.astro';
import Converter from '../../components/Converter';
import PricingCard from '../../components/PricingCard';
import { t } from '../../i18n/translations';

const lang = 'es';
---

<Layout title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang}>
  <section class="pt-16 pb-10 px-5">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 liquid-glass rounded-full px-4 py-1.5 text-[13px] font-medium text-text-secondary mb-6 animate-fade-in">
        <div class="w-2 h-2 rounded-full bg-primary-light animate-pulse-soft"></div>
        Motor de Conversion OCR
      </div>
      <h1 class="text-[40px] md:text-[52px] font-bold tracking-tight leading-[1.08] animate-slide-up">{t(lang, 'hero.title')}</h1>
      <p class="mt-5 text-[17px] text-text-muted max-w-lg mx-auto leading-relaxed animate-slide-up-delayed">{t(lang, 'hero.subtitle')}</p>
    </div>
  </section>
  <section class="pb-20 px-5"><div class="max-w-2xl mx-auto"><Converter lang={lang} client:load /></div></section>
  <section id="pricing" class="py-16 px-5">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-[28px] font-bold text-center mb-3 tracking-tight">{t(lang, 'pricing.title')}</h2>
      <p class="text-center text-text-muted text-[15px] mb-10">1 crédito = 1 página</p>
      <PricingCard lang={lang} client:visible />
    </div>
  </section>
</Layout>
