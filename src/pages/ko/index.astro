---
import Layout from '../../layouts/Layout.astro';
import Converter from '../../components/Converter';
import PricingCard from '../../components/PricingCard';
import { t } from '../../i18n/translations';

const lang = 'ko';
---

<Layout title={t(lang, 'site.title')} description={t(lang, 'site.description')} lang={lang}>
  <section class="pt-20 pb-12 px-5">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 liquid-glass rounded-full px-4 py-1.5 text-[13px] font-medium text-text-secondary mb-6 animate-fade-in">
        <div class="w-2 h-2 rounded-full bg-primary-light animate-pulse-soft"></div>
        OCR 기반 변환 엔진
      </div>
      <h1 class="text-[40px] md:text-[52px] font-bold tracking-tight leading-[1.08] animate-slide-up">{t(lang, 'hero.title')}</h1>
      <p class="mt-5 text-[17px] text-text-muted max-w-lg mx-auto leading-relaxed animate-slide-up-delayed">{t(lang, 'hero.subtitle')}</p>
    </div>
  </section>

  <section class="pb-20 px-5">
    <div class="max-w-2xl mx-auto"><Converter lang={lang} client:load /></div>
  </section>

  <section class="py-16 px-5">
    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-3 gap-5">
        <div class="rounded-2xl p-6 text-center border border-black/6 hover:border-black/12 transition-colors duration-300">
          <div class="w-12 h-12 mx-auto rounded-2xl overflow-hidden mb-4">
            <img src="/images/icon-table.jpg" alt="표 구조 인식" width="48" height="48" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-semibold text-[15px] mb-1.5 text-text">표 구조 인식</h3>
          <p class="text-[13px] text-text-muted leading-relaxed">OCR 엔진이 행, 열, 헤더를 높은 정확도로 감지</p>
        </div>
        <div class="rounded-2xl p-6 text-center border border-black/6 hover:border-black/12 transition-colors duration-300">
          <div class="w-12 h-12 mx-auto rounded-2xl overflow-hidden mb-4">
            <img src="/images/icon-secure.jpg" alt="보안 처리" width="48" height="48" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-semibold text-[15px] mb-1.5 text-text">보안 처리</h3>
          <p class="text-[13px] text-text-muted leading-relaxed">클라이언트 측 처리로 문서가 브라우저를 떠나지 않습니다</p>
        </div>
        <div class="rounded-2xl p-6 text-center border border-black/6 hover:border-black/12 transition-colors duration-300">
          <div class="w-12 h-12 mx-auto rounded-2xl overflow-hidden mb-4">
            <img src="/images/icon-export.jpg" alt="다양한 내보내기" width="48" height="48" class="w-full h-full object-cover" />
          </div>
          <h3 class="font-semibold text-[15px] mb-1.5 text-text">다양한 내보내기</h3>
          <p class="text-[13px] text-text-muted leading-relaxed">엑셀, 클립보드, Google Sheets</p>
        </div>
      </div>
    </div>
  </section>

  <section id="pricing" class="py-16 px-5">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-[28px] font-bold text-center mb-3 tracking-tight">{t(lang, 'pricing.title')}</h2>
      <p class="text-center text-text-muted text-[15px] mb-10">1 크레딧 = 1 페이지</p>
      <PricingCard lang={lang} client:visible />
    </div>
  </section>
</Layout>
